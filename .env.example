# Agent Evolver — Configuration
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────────────────
# Directories (CRITICAL: production dir must be writable only by dashboard publisher)
# ──────────────────────────────────────────────────────────
# Absolute path to your agent's production skill directory
EVOLVER_PRODUCTION_DIR=/path/to/your/agent/skills

# Absolute path for candidate staging area (evolution output goes here)
EVOLVER_CANDIDATE_DIR=/path/to/candidate/staging

# Absolute path for audit logs (append-only)
EVOLVER_AUDIT_DIR=/path/to/audit

# ──────────────────────────────────────────────────────────
# Upstream LLM (the real LLM endpoint your agent normally calls)
# ──────────────────────────────────────────────────────────
EVOLVER_UPSTREAM_BASE_URL=https://api.openai.com/v1
EVOLVER_UPSTREAM_API_KEY=sk-...
EVOLVER_UPSTREAM_MODEL=gpt-4o

# ──────────────────────────────────────────────────────────
# Proxy (intercepts agent LLM calls)
# ──────────────────────────────────────────────────────────
EVOLVER_PROXY_HOST=127.0.0.1
EVOLVER_PROXY_PORT=30000

# ──────────────────────────────────────────────────────────
# Dashboard (human review UI)
# ──────────────────────────────────────────────────────────
EVOLVER_DASHBOARD_HOST=127.0.0.1
EVOLVER_DASHBOARD_PORT=30001

# ──────────────────────────────────────────────────────────
# Evolution Engine
# ──────────────────────────────────────────────────────────
# Strategy preset: balanced | innovate | harden | repair-only
EVOLVER_STRATEGY=balanced

# Confidence threshold for auto-creating candidates (0.0-1.0)
EVOLVER_CONFIDENCE_THRESHOLD=0.7

# LLM used for evolution (can be different from upstream)
EVOLVER_LLM_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────────────────
# Strict mode: if true, refuse to start if production dir is writable
EVOLVER_STRICT_READONLY=false
